{
  "name": "dave-x",
  "version": "1.4.1",
  "description": "DAVE-X — Multi-platform WhatsApp Bot built on Baileys",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:gc": "node --expose-gc index.js",
    "start:low": "node --max-old-space-size=256 --optimize-for-size index.js",
    "start:mid": "node --max-old-space-size=512 index.js",
    "start:high": "node --max-old-space-size=1024 index.js",
    "dev": "node --trace-warnings index.js",
    "panel": "npm install --legacy-peer-deps && node index.js",
    "pm2": "pm2 start index.js --name DAVE-X --no-daemon",
    "pm2:gc": "pm2 start index.js --name DAVE-X --node-args='--expose-gc' --no-daemon",
    "pm2:stop": "pm2 stop DAVE-X",
    "pm2:restart": "pm2 restart DAVE-X",
    "pm2:logs": "pm2 logs DAVE-X",
    "install:deps": "npm install --legacy-peer-deps",
    "install:force": "npm install --force"
  },
  "keywords": [
    "whatsapp-bot",
    "baileys",
    "dave-x",
    "davetech"
  ],
  "author": "davetech-254",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@whiskeysockets/baileys": "npm:davexbaileys@2.5.21",
    "archiver": "^7.0.1",
    "awesome-phonenumber": "^7.8.0",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.6.2",
    "chalk": "^4.1.2",
    "chalk-animation": "^2.0.3",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "figlet": "^1.10.0",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.3",
    "gifted-btns": "^1.0.2",
    "google-tts-api": "^2.0.2",
    "got": "^14.6.6",
    "gradient-string": "^3.0.0",
    "gtts": "^0.2.1",
    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",
    "lodash": "^4.17.23",
    "moment-timezone": "^0.6.0",
    "mumaker": "^2.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "node-id3": "^0.2.9",
    "node-telegram-bot-api": "^0.67.0",
    "node-webpmux": "^3.2.1",
    "openai": "^6.27.0",
    "p-queue": "^9.1.0",
    "pastebin-js": "^1.0.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "randomstring": "^1.3.1",
    "ruhend-scraper": "^9.0.8",
    "sharp": "*",
    "similarity": "^1.2.1",
    "telegraf": "^4.16.3",
    "telegraf-ratelimit": "^2.0.0",
    "uuid": "^13.0.0",
    "wa-sticker-formatter": "^4.4.4",
    "webp-converter": "^2.3.3",
    "yargs": "^18.0.0",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5"
  },
  "overrides": {
